{
  "//": "Copy to .mcp.json and replace the absolute path. Claude Code reads .mcp.json from the project root. Build the server first: npm run build:mcp. No API key needed — the server is pure storage + retrieval; Claude does the structuring.",
  "mcpServers": {
    "koan": {
      "command": "node",
      "args": ["/ABSOLUTE/PATH/TO/koan/apps/mcp/dist/index.js"],
      "env": {
        "//KOAN_HOME": "optional — defaults to ~/.koan; set to point every Claude surface at the same store"
      }
    }
  }
}
