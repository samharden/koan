{
  "name": "koan",
  "version": "0.1.0",
  "private": true,
  "description": "Institutional knowledge capture & memory for law firms — a Claude MCP server + plugin over one local-first store.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:core": "npm run build -w @koan/core",
    "build:mcp": "npm run build -w @koan/mcp",
    "build": "npm run build:core && npm run build:mcp",
    "test": "npm run build:core && node --test \"packages/core/test/*.test.mjs\"",
    "mcp": "node apps/mcp/dist/index.js",
    "setup": "npm run build && node scripts/setup-plugin.mjs",
    "pack:mcpb": "node scripts/pack-mcpb.mjs",
    "install-skills": "node scripts/install-skills.mjs",
    "uninstall-skills": "node scripts/install-skills.mjs --uninstall"
  }
}
