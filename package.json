{
  "name": "knowledge-capture-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Institutional knowledge capture & memory for law firms — web app + Claude MCP plugin, sharing one local-first store.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*",
    "nextjs"
  ],
  "scripts": {
    "build:core": "npm run build -w @kg/core",
    "build:mcp": "npm run build -w @kg/mcp",
    "build": "npm run build:core && npm run build:mcp",
    "test": "npm run build:core && node --test \"packages/core/test/*.test.mjs\"",
    "mcp": "node apps/mcp/dist/index.js",
    "setup": "npm run build && node scripts/setup-plugin.mjs",
    "install-skills": "node scripts/install-skills.mjs",
    "uninstall-skills": "node scripts/install-skills.mjs --uninstall"
  }
}
